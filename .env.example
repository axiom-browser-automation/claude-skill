# Environment variables read by the skill's scripts.
# Copy to .env (which is gitignored) and fill in values, or export them in your shell.

# Long-lived API token from your Axiom account — used by run-axiom.js to
# trigger / poll saved axioms via the /v3/v4 REST surface. Mint from the
# dashboard, or use signup-and-mint-key.js to bootstrap a fresh one.
AXIOM_API_KEY=axm_your_key_here

# Required ONLY for signup-and-mint-key.js (account onboarding helper).
# Never set this via CLI args — keep it in the env so it stays out of process listings.
# AXIOM_PASSWORD=your-axiom-account-password

# Optional — base URL the run helper hits. Defaults to https://lar.axiom.ai (prod).
AXIOM_LAR_URL=https://lar.axiom.ai
